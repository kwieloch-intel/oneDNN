--reset
# No mask
--dt=f32,f16,bf16
--batch=shapes_basic

# Buffer mask (bf16 excluded: GPU kernel bug)
--reset
--mask_type=buffer
--dt=f32,f16
--batch=shapes_basic

# Broadcast buffer masks (1D and 2D, matching gtest oneD/twoD)
--reset
--mask_type=buffer_1d
--dt=f16,bf16
--batch=shapes_basic

--reset
--mask_type=buffer_2d
--dt=f16,bf16
--batch=shapes_basic

# Causal masks
--reset
--mask_type=causal_top_left
--dt=f32,f16
--batch=shapes_basic

--reset
--mask_type=causal_bottom_right
--dt=f32,f16
--batch=shapes_basic

# Scale
--reset
--scale_type=mul
--dt=f32,f16,bf16
--batch=shapes_basic

--reset
--scale_type=div
--dt=f32,f16
--batch=shapes_basic

# Transformer shapes
--reset
--dt=f16,bf16
--batch=shapes_transformer_gpu

--reset
--dt=f16,bf16
--mask_type=causal_top_left
--batch=shapes_transformer_gpu

# CI tests
--batch=test_sdpa_ci
